# Supabase 설정
SUPABASE_URL=your_supabase_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# 애플리케이션 설정
NODE_ENV=development
PORT=3000
PAGE_SIZE=20
DEFAULT_SORT_BY=rating
DEFAULT_SORT_ORDER=desc

# 리뷰 (단일 사용자)
REVIEW_USER_ID=local-user

# BGG 수집 (선택)
# BGG XML API 토큰이 있으면 설정 (없어도 일부 데이터는 가능)
BGG_APP_TOKEN=your_bgg_app_token
BGG_DUMP_URL=https://boardgamegeek.com/data_dumps/bg_ranks
BGG_DUMP_BATCH_SIZE=1000
BGG_DETAIL_BATCH_SIZE=20
BGG_DETAIL_SYNC_LIMIT=200
BGG_DETAIL_MIN_AGE_DAYS=0
BGG_DETAIL_RATE_LIMIT_MS=5000
# vercel-cron full 동기화에서만 적용되는 별도 rate limit
BGG_DETAIL_RATE_LIMIT_MS_CRON_FULL=1000
BGG_SYNC_RETRY_BASE_MINUTES=30
BGG_SYNC_RETRY_MAX_MINUTES=1440

# 크론 엔드포인트 보호용
CRON_SECRET=your_cron_secret

# BoardLife 알림 메일링 (선택)
BOARDLIFE_SITE_URL=https://boardlife.co.kr
BOARDLIFE_FEED_URL=https://boardlife.co.kr/feed_ajax.php
# 브라우저 로그인 후 획득한 Cookie 문자열
BOARDLIFE_COOKIE=
BOARDLIFE_NOTIFICATIONS_TABLE=external_notifications
BOARDLIFE_DELIVERIES_TABLE=notification_deliveries
BOARDLIFE_LOGIN_MODE=cookie
BOARDLIFE_LOGIN_URL=https://boardlife.co.kr
BOARDLIFE_USERNAME=
BOARDLIFE_PASSWORD=
BOARDLIFE_COOKIE_FILE=.boardlife.cookie
BOARDLIFE_COOKIE_TTL_MINUTES=120
BOARDLIFE_PLAYWRIGHT_HEADLESS=true
BOARDLIFE_PLAYWRIGHT_EXECUTABLE_PATH=
BOARDLIFE_PLAYWRIGHT_TIMEOUT_MS=30000
BOARDLIFE_PRINT_COOKIE=false
BOARDLIFE_TEST_MODE=false
BOARDLIFE_TEST_LATEST_COUNT=5

# SMTP 설정
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
BOARDLIFE_EMAIL_FROM=
BOARDLIFE_EMAIL_TO=
